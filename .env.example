# live-feed secrets. copy to .env (gitignored); the Makefile loads and exports it.
# free key from the dft bus open data service → data.bus-data.dft.gov.uk
# (enables real live buses; without it the frontend simulates trams instead).
BODS_API_KEY=
# anthropic key → llm geolocation of news headlines (else a gazetteer fallback).
ANTHROPIC_API_KEY=
