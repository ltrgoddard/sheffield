# optional secret. copy to .env (gitignored); the Makefile loads and exports it.
# anthropic key → llm geolocation of news headlines (else a gazetteer fallback).
# (live buses need no key — the frontend pulls them direct from bustimes.org.)
ANTHROPIC_API_KEY=
# sheffield tribune ghost content api key → the tribune layer (read-only, safe to rotate).
TRIBUNE_API_KEY=
